generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(uuid())
  email   String   @unique
  username String
  password String
  notes Note[]
  sessions Session[]
}

model Session {
  id String @id @default(uuid())
  refreshToken String   @unique
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
}

enum Tag {
  Todo
  Work
  Personal
  Meeting
  Shopping
  Ideas
  Travel
  Finance
  Health
  Important
}

model Note {
    id String @id @default(uuid())
    title String
    content String? @default("")
    tag Tag @default(Todo)
    createdAt DateTime @default(now())
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId String
}